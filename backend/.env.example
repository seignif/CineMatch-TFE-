# ============================================================
# CineMatch — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs manquantes
# NE PAS committer .env (déjà dans .gitignore)
# ============================================================

# Django
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL (Docker)
# Port 5433 pour éviter conflit avec PostgreSQL local
DB_NAME=cinematch
DB_USER=cinematch_user
DB_PASSWORD=cinematch_pass
DB_HOST=localhost
DB_PORT=5433

# ============================================================
# TMDb API — https://www.themoviedb.org/settings/api
# Rate limits : 1 000 requêtes/jour · 40 requêtes/10 secondes
# Gratuit (compte requis)
# ============================================================
TMDB_API_KEY=your-tmdb-api-key-here

# ============================================================
# MovieGlu API — https://developer.movieglu.com/
# Rate limits : 10 000 requêtes/mois (sandbox TFE)
# Territoire XX = données test tous pays
# Credentials fournis par MovieGlu après inscription
# ============================================================
MOVIEGLU_CLIENT=EPHE
MOVIEGLU_API_KEY=your-movieglu-api-key-here
MOVIEGLU_AUTHORIZATION=Basic your-base64-credentials-here
MOVIEGLU_TERRITORY=XX
MOVIEGLU_API_VERSION=v201
MOVIEGLU_BASE_URL=https://api-gate2.movieglu.com/

# Redis (Docker)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
